let tasks=[]; 
const totalEl=document.getElementById('totalCount'), doneEl=document.getElementById('completedCount'), activeEl=document.getElementById('activeCount'), listEl=document.getElementById('taskList'), themeSwitch=document.getElementById('themeSwitch'), body=document.body;
const tTab=document.getElementById('tasksTab'), sTab=document.getElementById('statsTab'), tContent=document.getElementById('tasksContent'), sContent=document.getElementById('statsContent');

function showTab(name){ if(name==='tasks'){ tContent.classList.add('active'); sContent.classList.remove('active'); tTab.classList.add('active'); sTab.classList.remove('active'); } else { tContent.classList.remove('active'); sContent.classList.add('active'); tTab.classList.remove('active'); sTab.classList.add('active'); updateStats(); } }

function load(){ const data=localStorage.getItem('tasks'); tasks=data?JSON.parse(data):[]; const theme=localStorage.getItem('theme')||'dark'; applyTheme(theme); themeSwitch.checked=theme==='dark'; showTab('tasks'); }

function save(){ localStorage.setItem('tasks', JSON.stringify(tasks)); localStorage.setItem('theme', body.classList.contains('dark')?'dark':'light'); }

function updateStats(){ totalEl.textContent=tasks.length; doneEl.textContent=tasks.filter(t=>t.completed).length; activeEl.textContent=tasks.length - tasks.filter(t=>t.completed).length; }

function render(){ listEl.innerHTML=''; tasks.forEach(t=>{ const li=document.createElement('li'), span=document.createElement('span'); span.textContent=t.text; span.className='task-text'; if(t.completed) span.classList.add('complete'); const toggleBtn=document.createElement('button'); toggleBtn.textContent=t.completed?'✓':'Выполнить'; toggleBtn.onclick=()=>{ t.completed=!t.completed; save(); render(); }; const delBtn=document.createElement('button'); delBtn.textContent='🗑️'; delBtn.onclick=()=>{ tasks=tasks.filter(e=>e.id!==t.id); save(); render(); }; li.appendChild(span); li.appendChild(toggleBtn); li.appendChild(delBtn); listEl.appendChild(li); }); updateStats(); }

function applyTheme(theme){ if(theme==='dark'){ body.classList.remove('light'); body.classList.add('dark'); }else{ body.classList.remove('dark'); body.classList.add('light'); } }

document.getElementById('addBtn').onclick=()=>{ const input=document.getElementById('taskInput'); if(input.value.trim()){ tasks.push({ id:Date.now(), text:input.value, completed:false }); input.value=''; save(); if(document.querySelector('.tab.active').id==='tasksTab') render(); } };

themeSwitch.onclick=()=>{ applyTheme(themeSwitch.checked?'dark':'light'); save(); };

tTab.onclick=()=>showTab('tasks'); sTab.onclick=()=>showTab('stats');

load(); render();
